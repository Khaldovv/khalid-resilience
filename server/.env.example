# ============ SERVER ============
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/grc_platform
JWT_SECRET=change-me-to-a-strong-random-secret-in-production
JWT_EXPIRY=8h
PORT=3001
NODE_ENV=development

# ============ AI CONFIGURATION (OpenRouter) ============
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxx

# Model selection (OpenRouter model IDs)
AI_PRIMARY_MODEL=qwen/qwen-2.5-72b-instruct
AI_FAST_MODEL=deepseek/deepseek-chat
AI_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct

# App URL (for OpenRouter referer header)
APP_URL=https://your-deployed-platform.com

# ============ CACHE ============
AI_CACHE_ENABLED=true
AI_CACHE_TTL_SECONDS=3600

# ============ CORS ============
# Comma-separated origins (defaults to localhost:5173,5174)
# CORS_ORIGINS=https://your-frontend.com,https://staging.your-frontend.com
FRONTEND_URL=https://khalid-resilience.vercel.app

# ============ LOGGING ============
LOG_LEVEL=info

# ============ ERROR TRACKING (optional) ============
# Create a project at https://sentry.io
# SENTRY_DSN=https://xxxx@yyy.ingest.sentry.io/zzz

# ============ FRONTEND SENTRY (optional) ============
# VITE_SENTRY_DSN=https://xxxx@yyy.ingest.sentry.io/zzz
